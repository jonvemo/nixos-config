{
  "orientation": "vertical",
  "icons": {
    "size": 24
  },
  "align": {
    "horizontal": "center",
    "vertical": "start",
    "width": 348,
    "margins": {
      "top": 0
    },
    "anchors": {}
  },
  "search": {
    "force_keyboard_focus": true,
    "icons": true,
    "history": true,
    "placeholder": "Search...",
    "delay": 0
  },
  "list": {
    "margin_top": 10,
    "height": 300,
    "always_show": false,
    "show_initial_entries": false,
    "scrollbar_policy": "automatic"
  },
  "modules": [
    {
      "name": "applications",
      "actions": true
    },
    {
      "name": "finder",
      "switcher_exclusive": true
    },
    {
      "name": "runner",
      "switcher_exclusive": true
    },
    {
      "name": "commands",
      "switcher_exclusive": true
    },
    {
      "prefix": "?",
      "name": "websearch"
    },
    {
      "prefix": "/",
      "name": "switcher"
    }
  ],
  "clipboard": {
    "image_height": 300,
    "max_entries": 10
  },
  "runner": {
    "Excludes": [
      "rm"
    ],
    "Includes": null
  }
}